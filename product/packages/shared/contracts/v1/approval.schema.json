{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclow.local/contracts/v1/approval.schema.json",
  "title": "Approval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "target_kind",
    "target_id",
    "decision",
    "actor",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "target_kind": {
      "type": "string",
      "enum": ["checkpoint", "promotion", "capability"]
    },
    "target_id": {
      "type": "string",
      "format": "uuid"
    },
    "decision": {
      "type": "string",
      "enum": ["approved", "rejected"]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "comment": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
