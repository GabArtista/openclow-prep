{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclow.local/contracts/v1/squad.schema.json",
  "title": "Squad",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "name",
    "version",
    "pipeline_id",
    "capability_ids"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "workspace_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "pipeline_id": {
      "type": "string",
      "format": "uuid"
    },
    "capability_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "memory_scope": {
      "type": "string",
      "enum": ["global", "squad", "run"]
    },
    "default_model_tier": {
      "type": "string",
      "enum": ["fast", "powerful"]
    }
  }
}
