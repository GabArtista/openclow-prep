{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclow.local/contracts/v1/pipeline.schema.json",
  "title": "Pipeline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "entry_step",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "version": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "entry_step": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./step.schema.json"
      }
    }
  }
}
